{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/urgencias-dentarias",
      "destination": "/urgencias",
      "permanent": true
    },
    {
      "source": "/urgencia-dentaria",
      "destination": "/urgencias",
      "permanent": true
    },
    {
      "source": "/dental-emergency",
      "destination": "/urgencias",
      "permanent": true
    },
    {
      "source": "/tratamentos/implantes-dentarios",
      "destination": "/tratamentos/implantologia",
      "permanent": true
    },
    {
      "source": "/tratamentos/branqueamento-dentario",
      "destination": "/tratamentos/estetica-dentaria",
      "permanent": true
    },
    {
      "source": "/tratamentos/dentisteria",
      "destination": "/tratamentos/caries",
      "permanent": true
    },
    {
      "source": "/tratamentos/prostodontia",
      "destination": "/tratamentos/proteses-dentarias",
      "permanent": true
    },
    {
      "source": "/tratamentos/aparelhos-dentarios",
      "destination": "/tratamentos/ortodontia",
      "permanent": true
    },
    {
      "source": "/tratamentos/criancas",
      "destination": "/tratamentos/odontopediatria",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ]
}
